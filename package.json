{
  "name": "meeting-notes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Meeting Notes PoC (Electron + React)",
  "main": "out/main/index.js",
  "scripts": {
    "preinstall": "node scripts/check-node.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "check:node": "node scripts/check-node.mjs",
    "test:smoke": "node scripts/test-smoke-electron.mjs",
    "measure:latency": "node scripts/measure-latency.mjs",
    "build:sidecar": "dotnet build sidecar/MeetingNotes.Sidecar.csproj -c Release",
    "dist:portable": "npm run build && electron-packager . meeting-notes --platform=win32 --arch=x64 --out=dist/portable --overwrite"
  },
  "dependencies": {
    "microsoft-cognitiveservices-speech-sdk": "^1.44.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "engines": {
    "node": ">=22.12.0 <23 || >=24.0.0 <24.16.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.1.0",
    "electron-packager": "^17.1.2",
    "electron-vite": "^2.3.0",
    "playwright": "^1.55.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
